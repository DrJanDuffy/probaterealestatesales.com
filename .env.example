# Copy to .env.local for local dev. Set in Vercel → Project → Environment Variables for production.

# Vercel Cron — Authorization: Bearer <CRON_SECRET> on GET /api/cron (random string, ≥16 chars)
CRON_SECRET=

# Google Search Console — HTML tag verification (public, safe to expose)
# https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Business Profile — public Maps / reviews URL (sameAs in JSON-LD + footer "Google reviews" link)
# Use the link from Google Business Profile → Share (maps.google.com, maps.app.goo.gl, etc.).
# When set to a Maps URL, hasMap + "View on Google" also use this URL (see src/config/site-google.ts).
# Example: https://www.google.com/maps?cid=YOUR_CID or https://maps.app.goo.gl/...
NEXT_PUBLIC_GOOGLE_BUSINESS_PROFILE_URL=

# Optional overrides if you need different URLs than the GBP link (leave unset to use logic above + address fallback).
# NEXT_PUBLIC_GOOGLE_MAPS_LISTING_URL=
# NEXT_PUBLIC_GOOGLE_MAPS_DIRECTIONS_URL=
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_SRC=
